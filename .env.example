# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App — production must be public HTTPS (not localhost) for Kashier webhooks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI & scraping (optional — demo mode without these)
GEMINI_API_KEY=
FIRECRAWL_API_KEY=

# Kashier payments (optional)
KASHIER_MERCHANT_ID=
KASHIER_API_KEY=
# Escape $ as \$ in .env.local
KASHIER_SECRET_KEY=
# Prefer this for webhook HMAC; falls back to SECRET_KEY then API_KEY
KASHIER_WEBHOOK_SECRET=
# Required in production: "test" or "live" (must match merchant dashboard keys)
KASHIER_MODE=test
# Sessions API is IP-whitelisted; local/dev uses hosted checkout by default.
# Set to true only after whitelisting this machine's IP in Kashier dashboard.
# KASHIER_FORCE_SESSION_API=true
# In production, set to true to skip Sessions API and always use HPP:
# KASHIER_SKIP_SESSION_API=true
# Also set the Kashier dashboard webhook URL to:
#   {NEXT_PUBLIC_APP_URL}/api/webhook/kashier

# Upstash Redis rate limiting (optional)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend email (optional)
RESEND_API_KEY=

# Local tryout: unlock Business features (ignored when NODE_ENV=production)
NEXT_PUBLIC_DEV_UNLOCK_ALL=true
