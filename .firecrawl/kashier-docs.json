    "amount": 50000,
    "currency": "EGP",
    "orderId": "ORD-2025-12345",
    "merchantId": "MERCHANT123",
    "orderHash": "generated_hash_above",
    "customerEmail": "customer@example.com",
    "customerPhone": "+201001234567",
    "customerName": "Ahmed Hassan",
    "items": [\
      {\
        "name": "Product Name",\
        "description": "Product Description",\
        "quantity": 1,\
        "unitPrice": 50000\
      }\
    ]
